# C++ Project .gitignore
# macOS (你之前加的)
.DS_Store
*.dSYM

# Windows (你需要的)
*.exe
*.dll
*.pdb
*.ilk
*.obj
*.lib
*.sdf
*.tlog
*.user

# Build Directories (编译文件夹)
build/
Debug/
Release/
x64/
x86/
*.suo
*.userosscache

# IDEs (VS Code / Visual Studio)
.vscode/
.vs/
*.swp
*.swo
# 无后缀脚本/可执行文件（按需取消注释）
scripts/run
bin/server
